{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "ESNext.Disposable",
      "DOM",
      "DOM.Iterable"
    ],
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@ifc-lite/wasm": [
        "packages/wasm/pkg/ifc-lite.d.ts"
      ],
      "@ifc-lite/wasm/*": [
        "packages/wasm/pkg/*"
      ],
      "@ifc-lite/geometry": [
        "packages/geometry/dist/index.d.ts"
      ],
      "@ifc-lite/geometry/*": [
        "packages/geometry/dist/*"
      ],
      "@ifc-lite/spatial": [
        "packages/spatial/dist/index.d.ts"
      ],
      "@ifc-lite/spatial/*": [
        "packages/spatial/dist/*"
      ],
      "@ifc-lite/ifcx": [
        "packages/ifcx/dist/index.d.ts"
      ],
      "@ifc-lite/ifcx/*": [
        "packages/ifcx/dist/*"
      ],
      "@ifc-lite/data": [
        "packages/data/dist/index.d.ts"
      ],
      "@ifc-lite/data/*": [
        "packages/data/dist/*"
      ],
      "@ifc-lite/mutations": [
        "packages/mutations/dist/index.d.ts"
      ],
      "@ifc-lite/mutations/*": [
        "packages/mutations/dist/*"
      ],
      "@ifc-lite/drawing-2d": [
        "packages/drawing-2d/dist/index.d.ts"
      ],
      "@ifc-lite/drawing-2d/*": [
        "packages/drawing-2d/dist/*"
      ],
      "@ifc-lite/encoding": [
        "packages/encoding/dist/index.d.ts"
      ],
      "@ifc-lite/encoding/*": [
        "packages/encoding/dist/*"
      ],
      "@ifc-lite/ids": [
        "packages/ids/dist/index.d.ts"
      ],
      "@ifc-lite/ids/*": [
        "packages/ids/dist/*"
      ],
      "@ifc-lite/lists": [
        "packages/lists/dist/index.d.ts"
      ],
      "@ifc-lite/lists/*": [
        "packages/lists/dist/*"
      ],
      "@ifc-lite/sdk": [
        "packages/sdk/dist/index.d.ts"
      ],
      "@ifc-lite/sdk/*": [
        "packages/sdk/dist/*"
      ],
      "@ifc-lite/sandbox": [
        "packages/sandbox/dist/index.d.ts"
      ],
      "@ifc-lite/sandbox/*": [
        "packages/sandbox/dist/*"
      ],
      "@ifc-lite/node-registry": [
        "packages/node-registry/dist/index.d.ts"
      ],
      "@ifc-lite/node-registry/*": [
        "packages/node-registry/dist/*"
      ],
      "@ifc-lite/viewer": [
        "packages/viewer/dist/index.d.ts"
      ],
      "@ifc-lite/viewer/*": [
        "packages/viewer/dist/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}