{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for IFC-Lite Desktop Viewer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:scope-appdata-recursive"
  ]
}
