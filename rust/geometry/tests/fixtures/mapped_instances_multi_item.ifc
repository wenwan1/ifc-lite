ISO-10303-21;
HEADER;
FILE_DESCRIPTION((''),'2;1');
FILE_NAME('mapped_instances_multi_item.ifc','2024-01-01T00:00:00',(''),(''),'ifc-lite','ifc-lite','');
FILE_SCHEMA(('IFC4'));
ENDSEC;
DATA;
#1=IFCCARTESIANPOINT((0.,0.,0.));
#2=IFCAXIS2PLACEMENT3D(#1,$,$);
#3=IFCSIUNIT(*,.LENGTHUNIT.,$,.METRE.);
#4=IFCUNITASSIGNMENT((#3));
#5=IFCGEOMETRICREPRESENTATIONCONTEXT($,'Model',3,1.0E-5,#2,$);
/* Solid A: 1x1 box, height 1, at profile origin */
#6=IFCCARTESIANPOINT((0.,0.));
#7=IFCAXIS2PLACEMENT2D(#6,$);
#8=IFCRECTANGLEPROFILEDEF(.AREA.,$,#7,1.0,1.0);
#9=IFCDIRECTION((0.,0.,1.));
#10=IFCAXIS2PLACEMENT3D(#1,$,$);
#11=IFCEXTRUDEDAREASOLID(#8,#10,#9,1.0);
/* Solid B: 2x1 box, height 1, offset +3 in X (geometrically distinct from A) */
#12=IFCCARTESIANPOINT((3.,0.));
#13=IFCAXIS2PLACEMENT2D(#12,$);
#14=IFCRECTANGLEPROFILEDEF(.AREA.,$,#13,2.0,1.0);
#15=IFCEXTRUDEDAREASOLID(#14,#10,#9,1.0);
/* MULTI-item MappedRepresentation: TWO direct solids under one RepresentationMap */
#16=IFCSHAPEREPRESENTATION(#5,'Body','SweptSolid',(#11,#15));
#17=IFCAXIS2PLACEMENT3D(#1,$,$);
#18=IFCREPRESENTATIONMAP(#17,#16);
/* Spatial structure */
#19=IFCLOCALPLACEMENT($,#2);
#20=IFCSITE('0SITE56789ABCDEFGHIJKL',$,'Site',$,$,#19,$,$,.ELEMENT.,$,$,$,$,$);
#21=IFCLOCALPLACEMENT(#19,#2);
#22=IFCBUILDING('0BLDG56789ABCDEFGHIJKL',$,'Building',$,$,#21,$,$,.ELEMENT.,$,$,$);
#23=IFCLOCALPLACEMENT(#21,#2);
#24=IFCBUILDINGSTOREY('0STRY56789ABCDEFGHIJKL',$,'Storey',$,$,#23,$,$,.ELEMENT.,0.);
#25=IFCPROJECT('0PRJ456789ABCDEFGHIJKL',$,'Proj',$,$,$,$,(#5),#4);
/* Four DISTINCT, non-identity MappingTargets (pure translations) */
#26=IFCCARTESIANPOINT((5.,0.,0.));
#27=IFCCARTESIANTRANSFORMATIONOPERATOR3D($,$,#26,$,$);
#28=IFCCARTESIANPOINT((0.,5.,0.));
#29=IFCCARTESIANTRANSFORMATIONOPERATOR3D($,$,#28,$,$);
#30=IFCCARTESIANPOINT((5.,5.,0.));
#31=IFCCARTESIANTRANSFORMATIONOPERATOR3D($,$,#30,$,$);
#32=IFCCARTESIANPOINT((0.,0.,7.));
#33=IFCCARTESIANTRANSFORMATIONOPERATOR3D($,$,#32,$,$);
/* Occurrence 0: map #18 with target #27, placement at (0,0,0) */
#34=IFCMAPPEDITEM(#18,#27);
#35=IFCSHAPEREPRESENTATION(#5,'Body','MappedRepresentation',(#34));
#36=IFCPRODUCTDEFINITIONSHAPE($,$,(#35));
#37=IFCCARTESIANPOINT((0.,0.,0.));
#38=IFCAXIS2PLACEMENT3D(#37,$,$);
#39=IFCLOCALPLACEMENT(#23,#38);
#40=IFCBUILDINGELEMENTPROXY('0PRX056789ABCDEFGHIJKL',$,'Proxy_0',$,$,#39,#36,$,$);
/* Occurrence 1: map #18 with target #29, placement at (10,0,0) */
#41=IFCMAPPEDITEM(#18,#29);
#42=IFCSHAPEREPRESENTATION(#5,'Body','MappedRepresentation',(#41));
#43=IFCPRODUCTDEFINITIONSHAPE($,$,(#42));
#44=IFCCARTESIANPOINT((10.,0.,0.));
#45=IFCAXIS2PLACEMENT3D(#44,$,$);
#46=IFCLOCALPLACEMENT(#23,#45);
#47=IFCBUILDINGELEMENTPROXY('0PRX156789ABCDEFGHIJKL',$,'Proxy_1',$,$,#46,#43,$,$);
/* Occurrence 2: map #18 with target #31, placement at (20,0,0) */
#48=IFCMAPPEDITEM(#18,#31);
#49=IFCSHAPEREPRESENTATION(#5,'Body','MappedRepresentation',(#48));
#50=IFCPRODUCTDEFINITIONSHAPE($,$,(#49));
#51=IFCCARTESIANPOINT((20.,0.,0.));
#52=IFCAXIS2PLACEMENT3D(#51,$,$);
#53=IFCLOCALPLACEMENT(#23,#52);
#54=IFCBUILDINGELEMENTPROXY('0PRX256789ABCDEFGHIJKL',$,'Proxy_2',$,$,#53,#50,$,$);
/* Occurrence 3: map #18 with target #33, placement at (30,0,0) */
#55=IFCMAPPEDITEM(#18,#33);
#56=IFCSHAPEREPRESENTATION(#5,'Body','MappedRepresentation',(#55));
#57=IFCPRODUCTDEFINITIONSHAPE($,$,(#56));
#58=IFCCARTESIANPOINT((30.,0.,0.));
#59=IFCAXIS2PLACEMENT3D(#58,$,$);
#60=IFCLOCALPLACEMENT(#23,#59);
#61=IFCBUILDINGELEMENTPROXY('0PRX356789ABCDEFGHIJKL',$,'Proxy_3',$,$,#60,#57,$,$);
/* Spatial aggregation + containment */
#62=IFCRELAGGREGATES('0REL156789ABCDEFGHIJKL',$,$,$,#25,(#20));
#63=IFCRELAGGREGATES('0REL256789ABCDEFGHIJKL',$,$,$,#20,(#22));
#64=IFCRELAGGREGATES('0REL356789ABCDEFGHIJKL',$,$,$,#22,(#24));
#65=IFCRELCONTAINEDINSPATIALSTRUCTURE('0REL456789ABCDEFGHIJKL',$,$,$,(#40,#47,#54,#61),#24);
ENDSEC;
END-ISO-10303-21;
