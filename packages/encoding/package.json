{
  "name": "@ifc-lite/encoding",
  "version": "1.14.9",
  "description": "IFC string encoding/decoding and property value parsing for IFC-Lite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/encoding"
  },
  "homepage": "https://ifclite.dev/docs/",
  "bugs": "https://github.com/LTplus-AG/ifc-lite/issues",
  "keywords": [
    "ifc",
    "bim",
    "encoding",
    "step",
    "aec"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
