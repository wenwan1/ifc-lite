{
  "name": "@ifc-lite/codegen",
  "version": "1.15.2",
  "description": "TypeScript code generator from IFC EXPRESS schemas",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/codegen"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "test": "vitest run",
    "generate": "node dist/cli.js",
    "generate:ifc4": "node dist/cli.js schemas/IFC4.exp -o generated/ifc4",
    "generate:ifc4x3": "node dist/cli.js schemas/IFC4X3.exp -o generated/ifc4x3"
  },
  "keywords": [
    "ifc",
    "express",
    "codegen",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^1.0.4"
  }
}
