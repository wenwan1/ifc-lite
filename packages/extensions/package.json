{
  "name": "@ifc-lite/extensions",
  "version": "0.3.4",
  "description": "Extension manifest, capability grammar, and slot registry for ifc-lite user customization",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    },
    "./capability": {
      "import": "./dist/capability/index.js",
      "types": "./dist/capability/index.d.ts"
    },
    "./when": {
      "import": "./dist/when/index.js",
      "types": "./dist/when/index.d.ts"
    },
    "./bundle": {
      "import": "./dist/bundle/index.js",
      "types": "./dist/bundle/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.0",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/extensions"
  },
  "homepage": "https://ifclite.dev/docs/",
  "bugs": "https://github.com/LTplus-AG/ifc-lite/issues",
  "keywords": [
    "ifc",
    "bim",
    "extensions",
    "manifest",
    "capability",
    "sandbox",
    "ai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
