{
  "name": "@ifc-lite/mcp",
  "version": "0.7.1",
  "description": "Model Context Protocol server for ifc-lite — agent-native BIM via MCP (stdio + Streamable HTTP)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ifc-lite-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./protocol": {
      "import": "./dist/protocol/index.js",
      "types": "./dist/protocol/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ifc-lite/bcf": "workspace:^",
    "@ifc-lite/clash": "workspace:^",
    "@ifc-lite/create": "workspace:^",
    "@ifc-lite/data": "workspace:^",
    "@ifc-lite/export": "workspace:^",
    "@ifc-lite/geometry": "workspace:^",
    "@ifc-lite/ids": "workspace:^",
    "@ifc-lite/mutations": "workspace:^",
    "@ifc-lite/parser": "workspace:^",
    "@ifc-lite/query": "workspace:^",
    "@ifc-lite/sdk": "workspace:^",
    "@ifc-lite/viewer-core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://ifclite.dev/docs/",
  "bugs": "https://github.com/LTplus-AG/ifc-lite/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ifc",
    "bim",
    "ai-agent",
    "llm",
    "claude",
    "cursor",
    "json-rpc",
    "ifc-lite",
    "aec"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
