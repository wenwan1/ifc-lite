{
  "name": "@ifc-lite/collab",
  "version": "0.2.5",
  "description": "Real-time collaborative BIM via CRDT on IFCX",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./snapshot": {
      "import": "./dist/snapshot/index.js",
      "types": "./dist/snapshot/index.d.ts"
    },
    "./providers/indexeddb": {
      "import": "./dist/providers/indexeddb.js",
      "types": "./dist/providers/indexeddb.d.ts"
    },
    "./providers/websocket": {
      "import": "./dist/providers/websocket.js",
      "types": "./dist/providers/websocket.d.ts"
    },
    "./awareness": {
      "import": "./dist/awareness/index.js",
      "types": "./dist/awareness/index.d.ts"
    },
    "./snapshot/worker": {
      "import": "./dist/snapshot/worker.js",
      "types": "./dist/snapshot/worker.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@ifc-lite/data": "workspace:^",
    "@ifc-lite/ifcx": "workspace:^",
    "@ifc-lite/mutations": "workspace:^",
    "lib0": "^0.2.99",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/collab"
  },
  "homepage": "https://ifclite.dev/docs/",
  "bugs": "https://github.com/LTplus-AG/ifc-lite/issues",
  "keywords": [
    "ifc",
    "ifcx",
    "ifc5",
    "bim",
    "collaboration",
    "crdt",
    "yjs",
    "real-time",
    "aec"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
