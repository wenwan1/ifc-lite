{
  "name": "@ifc-lite/renderer",
  "version": "1.35.2",
  "description": "WebGPU renderer for IFC-Lite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@ifc-lite/geometry": "workspace:^",
    "@ifc-lite/spatial": "workspace:^"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.71",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/renderer"
  },
  "homepage": "https://ifclite.dev/docs/",
  "bugs": "https://github.com/LTplus-AG/ifc-lite/issues",
  "keywords": [
    "ifc",
    "bim",
    "renderer",
    "webgpu",
    "aec"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
