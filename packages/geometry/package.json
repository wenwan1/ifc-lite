{
  "name": "@ifc-lite/geometry",
  "version": "3.3.0",
  "description": "Geometry processing bridge for IFC-Lite - exact-arithmetic CSG, streamed across workers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc && node -e \"const fs=require('fs');for(const f of ['dist/index.js','dist/geometry-parallel.js']){if(!fs.existsSync(f))continue;fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(/geometry\\.worker\\.ts/g,'geometry.worker.js'))}\"",
    "dev": "pnpm exec tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@ifc-lite/data": "workspace:^",
    "@ifc-lite/wasm": "workspace:^"
  },
  "optionalDependencies": {
    "@tauri-apps/api": "^2.11.1"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/geometry"
  },
  "homepage": "https://ifclite.dev/docs/",
  "bugs": "https://github.com/LTplus-AG/ifc-lite/issues",
  "keywords": [
    "ifc",
    "bim",
    "geometry",
    "mesh",
    "aec"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
