{
  "name": "@ifc-lite/viewer-core",
  "version": "0.2.4",
  "description": "Interactive 3D viewer for IFC models — WebGL 2 browser viewer with REST API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "test": "tsx --test test/*.test.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@ifc-lite/sdk": "workspace:^",
    "@ifc-lite/create": "workspace:^",
    "@ifc-lite/wasm": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/viewer"
  },
  "homepage": "https://ltplus-ag.github.io/ifc-lite/",
  "bugs": "https://github.com/LTplus-AG/ifc-lite/issues",
  "keywords": [
    "ifc",
    "bim",
    "viewer",
    "3d",
    "webgl",
    "aec",
    "ifc-lite"
  ],
  "publishConfig": {
    "access": "public"
  }
}
